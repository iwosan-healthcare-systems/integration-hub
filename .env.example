# ════════════════════════════════════════════════════════════════════════════
#  Iwosan Innovation Hub — Environment Variables
#  Copy this file to .env (CPanel server) or .env.local (local dev).
#  NEVER commit .env or .env.local — they are gitignored.
# ════════════════════════════════════════════════════════════════════════════

# ── Frontend (Vite) ────────────────────────────────────────────────────────
# Local dev: http://localhost:3001
# Production: set in your deployment dashboard (Netlify / Vercel) instead,
#             or in this file if you are self-hosting.
VITE_API_BASE_URL=https://api.iwosaninnovationhub.com

# ── Express API server — place this file as .env on the CPanel server ─────
# IMPORTANT: on CPanel use localhost — the DB is on the same server.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iwosan_innovation_hub
DB_USER=hub_admin
DB_PASSWORD=your_db_password
DB_SSL=false

# JWT — generate a fresh secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret

# Cookie is shared between iwosaninnovationhub.com and api.iwosaninnovationhub.com
COOKIE_DOMAIN=.iwosaninnovationhub.com

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://iwosaninnovationhub.com

# CPanel Passenger sets PORT automatically — leave as 3001 only for local dev
PORT=3001
NODE_ENV=production

# ── Azure AD — Microsoft Sign-In (3 organisations) ────────────────────────
# Each organisation has its own App Registration in their Azure AD tenant.
#
# Azure Portal setup per org (repeat for each):
#   1. Azure Active Directory → App registrations → New registration
#   2. Name: "Iwosan Innovation Hub"
#   3. Supported account types: "Accounts in this organizational directory only"
#   4. Platform: Single-page application
#   5. Redirect URIs: https://iwosaninnovationhub.com  (add http://localhost:5173 for dev)
#   6. Authentication → check "ID tokens" under Implicit grant
#   7. Copy the Application (client) ID and Directory (tenant) ID below

# Lagoon Hospitals
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=

# Iwosan Healthcare
AZURE_HEALTHCARE_CLIENT_ID=
AZURE_HEALTHCARE_TENANT_ID=
VITE_AZURE_HEALTHCARE_CLIENT_ID=
VITE_AZURE_HEALTHCARE_TENANT_ID=

# Euracare
AZURE_EURACARE_CLIENT_ID=
AZURE_EURACARE_TENANT_ID=
VITE_AZURE_EURACARE_CLIENT_ID=
VITE_AZURE_EURACARE_TENANT_ID=

# ── Groq AI (for the Iwo chatbot) ─────────────────────────────────────────
# Get a free key at https://console.groq.com → API Keys → Create API key
GROQ_API_KEY=gsk_...


